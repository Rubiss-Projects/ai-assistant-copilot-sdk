{
  "name": "ai-assistant",
  "version": "1.2.1",
  "description": "Personal Discord bot backed by the GitHub Copilot SDK",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rubiss/ai-assistant-copilot-sdk.git"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "ai-assistant": "./dist/src/cli.js"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "test": "node --import tsx --test tests/*.test.ts",
    "register": "tsx scripts/register-commands.ts",
    "postinstall": "node dist/scripts/patch-deps.cjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@github/copilot-sdk": "^1.0.5",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "undici": "^6.24.0"
  }
}
